;; EDN representation of the Geometry of ReSTIR/GRIS visual essay series
;;
;; Each entry in the top‑level vector corresponds to one HTML essay or guide.
;; The structure captures high–level semantics rather than raw markup.  It
;; shows the essay title, filename, a list of sections, and within each
;; section a nested list of either paragraphs (:p) or interactive modules
;; (:interactive) with descriptive titles and summaries.  Attributes are
;; deliberately kept minimal; the goal of this intermediate representation
;; is to expose hierarchical structure and semantics to downstream
;; transforms.

[
  {:title "Pushforward & Pullback"
   :filename "essay-01-pushforward-pullback.html"
   :sections [
     {:title "Introduction"
      :content [[:p "Explains that samples move forward while tests move backward."]
               [:interactive {:name "Sample vs. test propagation"
                               :description "An animation where particles move forward through a transport map while a heatmap of importance propagates backwards."}]
               [:p "Introduces the fundamental pushforward/pullback duality and the pairing \u2208int φ d(T_#\u03bc) = \u2208int (T^*\u03c6) d\u03bc."]]}]
   :notes "Establishes the dual nature of transport: pushforwards move measures and pullbacks move observables."}

  {:title "Residual Measure Transport"
   :filename "essay-02-residual-measure-transport.html"
   :sections [
     {:title "Prediction vs Evidence"
      :content [[:p "Defines predicted measure \u03bc^- and incoming evidence \u03bd."]
               [:interactive {:name "Prediction/evidence overlay"
                               :description "Overlay the predicted distribution and the observed distribution, highlighting residual mass."}]]}
     {:title "Residual and Decomposition"
      :content [[:p "Defines the residual \u03c1 = \u03bd - \u03bc^- and the Lebesgue decomposition into expected and singular components."]
               [:interactive {:name "Signed residual measure"
                               :description "Visualises positive and negative regions of the residual and the singular novelty component."}]]}
     {:title "First‑order vs Second‑order"
      :content [[:p "Compares first‑order error e_t and second‑order error \u0394e_t."]
               [:interactive {:name "Residual derivatives"
                               :description "Controls to vary first‑order and second‑order residuals and see their impact on attention."}]]}
     {:title "Attention and Allocation"
      :content [[:p "Explains how residual magnitude, residual acceleration and singular novelty drive sampling budget."}
               [:interactive {:name "Attention field"
                               :description "Maps residual metrics to reuse trust and sample allocation."}]]}
   ]
   :notes "Reformulates sampling as focusing on what the prediction failed to explain."}

  {:title "Biomimetic Reservoir Intelligence"
   :filename "essay-03-biomimetic-reservoir-intelligence.html"
   :sections [
     {:title "Bounded Belief"
      :content [[:p "Explains that both renderers and biological vision maintain a finite reservoir of hypotheses about the world rather than resampling it in full."]
               [:interactive {:name "Saccades as proposals"
                               :description "Simulates an eye scanning a scene, showing how saccades propose candidate hypotheses rather than raw pixels."}]]}
     {:title "Prediction, Evidence & Residual"
      :content [[:p "Shows the loop of predicting the next state, comparing with evidence, extracting the residual and updating the reservoir."]
               [:interactive {:name "Hallucination vs update"
                               :description "Demonstrates ghosting when high confidence in stale samples overwhelms evidence, and how residual sampling cures it."}]]}
     {:title "Biomimetic Pass Architecture"
      :content [[:p "Outlines a renderer pipeline inspired by visual cognition: stability filter, predictive transport, novelty gate, proposal channels and GRIS merge."]
               [:interactive {:name "Renderer block diagram"
                               :description "Interactive diagram connecting each stage of the biomimetic rendering loop."}]]}
   ]
   :notes "Draws parallels between ReSTIR reuse and attentional mechanisms in biological vision."}

  {:title "The Shape of a Reservoir"
   :filename "essay-04-shape-of-a-reservoir.html"
   :sections [
     {:title "Reservoir Cloud"
      :content [[:p "Presents the reservoir as an empirical probability cloud rather than a single sample."]
               [:interactive {:name "Reservoir shape controls"
                               :description "Sliders for entropy, anisotropy, number of modes and cardinality, with a visualisation of the resulting point cloud."}]]}
     {:title "Transport Deformation"
      :content [[:p "Illustrates how transport maps can stretch, twist or fold the reservoir and introduces the Jacobian as density correction."]
               [:interactive {:name "Deformed reservoir"
                               :description "Shows identity, stretch, fold and split maps acting on a reservoir and plots the associated Jacobian weights."}]]}
     {:title "Confidence vs Weight"
      :content [[:p "Distinguishes between the weight a sample contributes to the estimator and the confidence that the sample remains relevant under reuse."]
               [:interactive {:name "Confidence heatmap"
                               :description "Visualises reuse confidence separately from contribution weight."}]]}
     {:title "Adaptive Cardinality"
      :content [[:p "Describes how reservoir cardinality adapts to local entropy, curvature, novelty and a maximum budget."]
               [:interactive {:name "Adaptive K field"
                               :description "Allocates representatives based on measured complexity and displays the distribution across pixels."}]]}
     {:title "Reservoir Hierarchy"
      :content [[:p "Shows that reservoirs exist at multiple levels: pixel, tile, object, material and scene."}
               [:interactive {:name "Reservoir tower"
                               :description "A vertical diagram linking different reservoir scopes and their interactions."}]]}
   ]
   :notes "Emphasises that a reservoir is a shaped empirical measure, not a single sample, and introduces adaptive cardinality."}

  {:title "Curvature of Reuse"
   :filename "essay-05-curvature-of-reuse.html"
   :sections [
     {:title "Temporal vs Spatial Loops"
      :content [[:p "Defines the smallest screen–time loop: spatial then temporal vs temporal then spatial reuse."]
               [:interactive {:name "Commutator loop"
                               :description "Transports a reservoir around a square via two different orderings and displays the resulting divergence."}]]}
     {:title "Commutator Microscope"
      :content [[:p "Provides diagnostic metrics such as centroid distance, entropy delta, visibility mismatch and Jacobian instability for measuring disagreement between transport paths."]
               [:interactive {:name "Curvature metrics"
                               :description "Plots different curvature proxies and lets the user explore where they become large."}]]}
     {:title "Artifact Heatmap"
      :content [[:p "Maps curvature hotspots to rendering artifacts like ghosting, shimmer and fireflies."]
               [:interactive {:name "Curvature field"
                               :description "Shows synthetic scenes with disocclusion, moving objects and glossy ridges and overlays a curvature heatmap."}]]}
     {:title "Reuse Valve"
      :content [[:p "Formulates reuse trust as an exponential of residual, curvature and novelty and derives sample pressure from it."]
               [:interactive {:name "Reuse trust control"
                               :description "Controls to adjust coefficients for residual, curvature and novelty and observe the effect on reuse gating."}]]}
     {:title "Production Pass"
      :content [[:p "Sketches a production implementation of curvature‑aware reuse: estimating curvature, modulating reuse confidence and allocating new samples."]
               [:interactive {:name "Pass pseudocode"
                               :description "Displays annotated pseudocode for computing curvature and applying it in a ReSTIR pass."}]]}
   ]
   :notes "Shows that noncommuting transport operators reveal curved regions where reuse should be limited."}

  {:title "A Pixel Is Not a Point"
   :filename "essay-06-pixel-is-not-a-point.html"
   :sections [
     {:title "Pixel vs Point"
      :content [[:p "Argues that a pixel is a base point in screen–time, while the actual integrand lives in an attached fiber of path space."}
               [:interactive {:name "Pixel fibre reveal"
                               :description "Click a pixel to reveal the hidden cloud of paths \u03a9_p above it."}]]}
     {:title "Inside the Fibre"
      :content [[:p "Explores the contents of \u03a9_p: number of candidates, entropy and anisotropy."}
               [:interactive {:name "Fibre shape controls"
                               :description "Tunable parameters for the fibre's complexity with immediate visual feedback."}]]}
     {:title "Transport Between Fibres"
      :content [[:p "Shows reuse as transport between distinct path‑space fibres and introduces Jacobian correction."}
               [:interactive {:name "Fibre transport"
                               :description "Animates reservoirs moving from one fibre to another through different types of maps."}]]}
     {:title "Screen–Time Bundle"
      :content [[:p "Constructs the base manifold B = screen × time and attaches fibres \u03a9_p above each point, forming a bundle."}
               [:interactive {:name "Bundle visualisation"
                               :description "Displays the bundle as a sheet with fibres rising above each pixel and twisting near complex regions."}]]}
     {:title "Transport Rules as Connections"
      :content [[:p "Interprets motion vectors, surface shifts, object transforms and learned path shifts as different connection rules on the bundle."}
               [:interactive {:name "Connection gallery"
                               :description "Compare different connection rules and their effect on transported reservoirs."}]]}
     {:title "Renderer Data Model"
      :content [[:p "Presents a pseudocode structure for a FibreReservoir with fields for base index, source fibre, transport kind, Jacobian, fibre distance, residual, curvature and confidence."]]}]
   :notes "Gives the geometric foundation: renderers operate on a bundle of path spaces rather than a flat image plane."}

  {:title "The Geometry of Light Transport"
   :filename "essay-07-geometry-of-light-transport.html"
   :sections [
     {:title "Rendering Equation as Measure Evaluation"
      :content [[:p "Recalls that a pixel value is an integral of a shading function against a path‑space measure."]
               [:interactive {:name "Integrator widget"
                               :description "Lets the user change shading functions (diffuse, glossy, shadow, caustic) and see how the integral changes."}]]}
     {:title "Continuous Measure to Empirical Reservoir"
      :content [[:p "Explains how a continuous path measure is approximated by a finite weighted reservoir for practical rendering."]
               [:interactive {:name "Reservoir approximation"
                               :description "Shows a continuous probability density alongside a finite set of representative samples."}]]}
     {:title "GRIS Transport and Jacobian Pressure"
      :content [[:p "Demonstrates GRIS as transporting samples between domains with density correction via the Jacobian."}
               [:interactive {:name "GRIS shift gallery"
                               :description "Identity, stretch, fold and visibility‑split shifts visualised with associated Jacobian weights."}]]}
     {:title "Pushforward / Pullback Duality"
      :content [[:p "Combines pushforwards and pullbacks to show that evaluating a pushed‑forward measure against an observable equals evaluating the original measure against the pulled‑back observable."}
               [:interactive {:name "Duality demonstration"
                               :description "Parallel animations of moving samples and moving test functions to evaluate the same integral."}]]}
     {:title "Residual and Curvature in the Estimator"
      :content [[:p "Incorporates residuals and curvature into the estimator: residual samples the mismatch; curvature measures failure of transport commutativity."}
               [:interactive {:name "Residual + curvature"
                               :description "Plots how residual and curvature modulate reuse trust in a unified estimator."}]]}
     {:title "Unified Geometric Machine"
      :content [[:p "Summarises the entire pipeline: screen–time base, fibres, empirical reservoirs, transport maps, pushforward/pullback pairing, residual novelty and curvature‑aware reuse."]
               [:interactive {:name "Unified diagram"
                               :description "An interactive schematic connecting all concepts introduced in the series."}]]}
   ]
   :notes "Provides the keystone that unites the rendering equation, reservoirs, GRIS, pushforwards, pullbacks, residuals and curvature into one geometric framework."}

  {:title "Curvature‑Guided Sampling"
   :filename "essay-08-curvature-guided-sampling.html"
   :sections [
     {:title "Residual Controller"
      :content [[:p "Defines a parametric controller that maps residual, curvature, novelty, entropy, salience and coefficients \u03bb to reuse trust and sample allocation."]
               [:interactive {:name "Controller panel"
                               :description "Sliders for tuning the parameters and seeing the resulting reuse trust and sample count."}]]}
     {:title "Attention and Sample Pressure Field"
      :content [[:p "Applies the controller to synthetic scenes and visualises the distribution of sample pressure across pixels."]
               [:interactive {:name "Sample pressure field"
                               :description "A heatmap showing where more or fewer samples are allocated based on the controller."}]]}
     {:title "Reuse Valve"
      :content [[:p "Illustrates failure modes (flat wall, moving object, disocclusion, glossy fold, stale reservoir) and shows how reuse trust decreases with increasing residual and curvature."}
               [:interactive {:name "Failure mode selector"
                               :description "Choose a failure mode and observe how the controller modulates reuse trust and sample pressure."}]]}
     {:title "Pass Architecture"
      :content [[:p "Outlines the production rendering pass: stability analysis, prediction, novelty gate, proposal generation, GRIS merge, shading and diagnostics."]
               [:interactive {:name "Pass diagram"
                               :description "A block diagram connecting each stage of the curvature‑guided rendering loop."}]]}
     {:title "Falsifiability Diagnostics"
      :content [[:p "Shows correlation panels between residual, curvature, novelty and observed artifacts to validate the curvature‑guided sampling theory."]
               [:interactive {:name "Diagnostics panels"
                               :description "Plots residual vs artifact intensity, curvature vs reuse trust and similar metrics to assess the controller."}]]}
   ]
   :notes "Provides a practical control loop where variance becomes geometry and ties together all previous essays."}

  {:title "Series Guide"
   :filename "restir_geometry_series_guide.html"
   :sections [
     {:title "Welcome"
      :content [[:p "Introduces the series and explains the motivation for recasting ReSTIR/GRIS in geometric terms."]
               [:p "Recommends reading order and notes that readers can dip into individual chapters."]]}
     {:title "Essays Overview"
      :content [[:p "Summarises each essay in one or two sentences."]
               [:interactive {:name "Series map"
                               :description "An interactive map linking chapters and showing dependencies between concepts."}]]}
     {:title "Reading Routes"
      :content [[:p "Suggests alternative routes through the material for different audiences: graphics engineers, mathematicians, cognitive scientists, and implementers."]]}
     {:title "Index"
      :content [[:p "Provides a compact index of core concepts (pushforward, pullback, residual, curvature, fibre, connection, etc.) with links back to the essays."]]}]
   :notes "Serves as the landing page and roadmap for the entire series."}
]